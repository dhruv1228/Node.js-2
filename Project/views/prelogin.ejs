<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Home</title>
</head>
<body>
  <script src="https://cdn.tailwindcss.com"></script>

  <nav class="bg-white shadow">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16 items-center">
        <a href="/" class="text-xl font-semibold text-indigo-600">YourApp</a>
        <div class="flex items-center space-x-4">
          <a href="/login" class="text-gray-700 hover:text-indigo-600">Log in</a>
          <a href="/signup" class="px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700">Sign up</a>
        </div>
      </div>
    </div>
  </nav>

  <main class="min-h-[calc(100vh-64px)] flex items-center justify-center bg-gradient-to-br from-gray-50 to-white py-12">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <div class="bg-white shadow-lg rounded-2xl overflow-hidden grid grid-cols-1 lg:grid-cols-2">
        <div class="p-10 lg:p-16 flex flex-col justify-center">
          <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900">Welcome to YourApp</h1>
          <p class="mt-4 text-gray-600">A short description that explains what your app does and how it helps users. Sign up to get started or log in if you already have an account.</p>
          <div class="mt-8 flex gap-4">
            <a href="/signup" class="inline-flex items-center justify-center px-6 py-3 bg-indigo-600 text-white rounded-md shadow hover:bg-indigo-700">Get Started</a>
            <a href="/login" class="inline-flex items-center justify-center px-6 py-3 border border-gray-200 text-gray-700 rounded-md hover:bg-gray-50">Log in</a>
          </div>
        </div>
        <div class="hidden lg:block bg-indigo-50 p-10">
          <div class="h-full flex items-center justify-center">
            <div class="w-full max-w-sm bg-white rounded-xl shadow p-6">
              <h3 class="text-lg font-semibold text-gray-800">Quick preview</h3>
              <p class="mt-2 text-sm text-gray-600">A quick glimpse of the dashboard or features to entice users.</p>
              <div class="mt-4 space-y-3">
                <div class="h-3 bg-gray-200 rounded w-3/4"></div>
                <div class="h-3 bg-gray-200 rounded w-1/2"></div>
                <div class="h-3 bg-gray-200 rounded w-5/6"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <footer class="text-center text-sm text-gray-500 py-6">© <%= new Date().getFullYear() %> YourApp. All rights reserved.</footer>
</body>
</html>